<%= render layout: "shared/auth_card" do %>
  <h1 class="text-center text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Sign up</h1>
  <p class="mt-1 text-center text-sm text-slate-600">
    Already have an account?
    <%= link_to "Sign in", sign_in_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
  </p>

  <%= form_with(url: sign_up_path, class: "mt-8 space-y-5") do |form| %>
    <% if @user.errors.any? %>
      <div class="<%= tw_alert_error_classes %> space-y-1" role="alert">
        <p class="font-medium"><%= pluralize(@user.errors.count, "error") %> prevented saving:</p>
        <ul class="list-inside list-disc text-sm">
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email, class: tw_label_classes %>
      <%= form.email_field :email, value: @user.email, required: true, autofocus: true, autocomplete: "email", class: tw_input_classes %>
    </div>

    <div>
      <%= form.label :password, class: tw_label_classes %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", class: tw_input_classes %>
      <p class="mt-1 text-xs text-slate-500">12 characters minimum.</p>
    </div>

    <div>
      <%= form.label :password_confirmation, class: tw_label_classes %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: tw_input_classes %>
    </div>

    <div class="pt-1">
      <%= form.submit "Sign up", class: tw_btn_primary_classes %>
    </div>
  <% end %>
<% end %>
