<% content_for(:title, "#{@book.title} — Rocketbox") %>

<%= render "shared/page_header" %>

<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
  <%= render "toc", chapters: @chapters, active_chapter: nil %>

  <article class="rb-surface-form min-w-0 flex-1 p-6 rb-shadow-card sm:p-8">
    <p class="text-xs font-medium uppercase tracking-[0.06em] text-ink-500">Guide preview</p>
    <h1 class="mt-2 font-manrope text-3xl font-extrabold tracking-[-0.02em] text-ink-900 sm:text-4xl">
      <%= @book.title %>
    </h1>
    <p class="mt-4 text-lg font-medium leading-relaxed text-ink-500">
      A field-style walkthrough for operators who run the floor. This mock page stands in for the catalog:
      <%= @book.chapters.size %> chapters, each with the same reader layout—navigation on the left, long-form notes on the right.
    </p>

    <div class="mt-8 space-y-4 text-[17px] font-medium leading-relaxed text-ink-700">
      <p>
        Use the table of contents to jump into any chapter. The copy below is placeholder content so designers and engineers
        can wire layout, typography, and paywall seams before the real manuscript ships.
      </p>
      <p>
        In production you might show download links, subscription state, print styles, or “resume where you left off” here on
        the overview.
      </p>
    </div>

    <h2 class="mt-10 text-lg font-semibold text-ink-900">What you’ll find inside</h2>
    <ul class="mt-3 list-inside list-disc space-y-2 text-ink-700">
      <li>Checklists formatted like shift notes, not MBA slides</li>
      <li>Margin and labor prompts you can answer in ten minutes</li>
      <li>Scripts and defaults your team can rely on when it’s busy</li>
    </ul>

    <%= render "shared/subscription_action_buttons", container_class: "mt-10 flex flex-wrap gap-3" %>
  </article>
</div>
