<nav class="lg:sticky lg:top-8" aria-label="Table of contents">
  <div class="rb-surface-form p-4 rb-shadow-card sm:p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.06em] text-ink-500">Table of contents</p>
    <ul class="mt-3 space-y-0.5 text-sm text-ink-700">
      <li>
        <%= link_to books_book_path(@book),
              class: [
                "flex rounded-[10px] px-2 py-2 font-medium transition hover:bg-ink-900/5",
                (local_assigns[:active_chapter].nil? ? "bg-rocket/15 text-ink-900" : "text-ink-800"),
              ].join(" ") do %>
          <div class="text-ink-500">Overview</div>
        <% end %>
      </li>
    </ul>
    <ol class="mt-1 max-h-[min(70vh,40rem)] space-y-0.5 overflow-y-auto pr-1 text-sm">
      <% chapters.each do |chapter| %>
        <% locked = chapter_locked?(chapter) %>
        <li>
          <% if locked %>
            <div class="flex cursor-not-allowed items-start gap-2 rounded-[10px] px-2 py-1.5 leading-snug text-ink-400"
                 aria-disabled="true"
                 title="Subscribe for full access to this chapter">
              <div class="shrink-0 tabular-nums"><%= chapter.position %>.</div>
              <div class="min-w-0 flex-1"><%= chapter.title %></div>
              <%= heroicon "lock-closed", variant: :micro, options: { class: "size-3 shrink-0 text-ink-400", "aria-hidden": true } %>
            </div>
          <% else %>
            <%= link_to books_book_chapter_path(@book, chapter),
                  class: [
                    "flex items-start gap-2 rounded-[10px] px-2 py-1.5 leading-snug transition hover:bg-ink-900/5",
                    (local_assigns[:active_chapter] == chapter.slug ? "bg-rocket/15 font-medium text-ink-900" : "text-ink-700"),
                  ].join(" ") do %>
              <div class="shrink-0 tabular-nums text-ink-400"><%= chapter.position %>.</div>
              <div class="min-w-0 flex-1"><%= chapter.title %></div>
              <div class="size-3 shrink-0" aria-hidden="true"></div>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ol>
  </div>
</nav>
