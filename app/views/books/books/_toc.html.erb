<nav class="lg:sticky lg:top-8" aria-label="Table of contents">
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Table of contents</p>
    <ul class="mt-3 space-y-0.5 text-sm text-slate-700">
      <li>
        <%= link_to books_book_path(@book),
              class: [
                "flex rounded-lg px-2 py-2 font-medium transition hover:bg-slate-50",
                (local_assigns[:active_chapter].nil? ? "bg-indigo-50 text-indigo-900" : "text-slate-800"),
              ].join(" ") do %>
          <div class="text-slate-500">Overview</div>
        <% end %>
      </li>
    </ul>
    <ol class="mt-1 max-h-[min(70vh,40rem)] space-y-0.5 overflow-y-auto pr-1 text-sm">
      <% chapters.each do |chapter| %>
        <% locked = chapter_locked?(chapter) %>
        <li>
          <% if locked %>
            <div class="flex items-start gap-2 rounded-lg px-2 py-1.5 leading-snug text-slate-400 cursor-not-allowed"
                 aria-disabled="true"
                 title="Subscribe to unlock this chapter">
              <div class="shrink-0 tabular-nums"><%= chapter.position %>.</div>
              <div class="min-w-0 flex-1"><%= chapter.title %></div>
              <%= heroicon "lock-closed", variant: :micro, options: { class: "size-3 shrink-0 text-slate-400", "aria-hidden": true } %>
            </div>
          <% else %>
            <%= link_to books_book_chapter_path(@book, chapter.position),
                  class: [
                    "flex items-start gap-2 rounded-lg px-2 py-1.5 leading-snug transition hover:bg-slate-50",
                    (local_assigns[:active_chapter] == chapter.position ? "bg-indigo-50 font-medium text-indigo-900" : "text-slate-700"),
                  ].join(" ") do %>
              <div class="shrink-0 tabular-nums text-slate-400"><%= chapter.position %>.</div>
              <div class="min-w-0 flex-1"><%= chapter.title %></div>
              <div class="size-3 shrink-0" aria-hidden="true"></div>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ol>
  </div>
</nav>
