<% content_for(:title, "Chapter #{@chapter.position}: #{@chapter.title} — #{@book.title}") %>

<%= render "shared/page_header" %>

<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
  <%= render "toc", chapters: @chapters, active_chapter: @chapter.slug %>

  <article class="rb-surface-form min-w-0 flex-1 p-6 rb-shadow-card sm:p-8">
    <p class="text-sm text-ink-500">
      <%= link_to "Overview", books_book_path(@book), class: "font-medium text-rocket hover:text-rocket-hover" %>
      <span class="mx-1 text-ink-400" aria-hidden="true">/</span>
      <span class="text-ink-500">Chapter <%= @chapter.position %> of <%= @book.chapters.size %></span>
    </p>

    <h1 class="mt-4 font-manrope text-3xl font-extrabold tracking-[-0.02em] text-ink-900 sm:text-4xl">
      <%= @chapter.title %>
    </h1>

    <div class="document-body mt-8 max-w-none space-y-4 text-[17px] font-medium leading-relaxed text-ink-700 [&_h1]:mt-8 [&_h1]:font-manrope [&_h1]:text-2xl [&_h1]:font-extrabold [&_h1]:text-ink-900 [&_h2]:mt-8 [&_h2]:scroll-mt-24 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-ink-900 [&_h3]:mt-6 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-ink-900 [&_p]:mt-3 [&_p]:first:mt-0 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:mt-3 [&_ol]:list-decimal [&_ol]:pl-5 [&_li]:mt-1 [&_a]:font-medium [&_a]:text-rocket [&_a]:underline [&_a:hover]:text-rocket-hover [&_strong]:font-semibold [&_code]:rounded [&_code]:bg-paper-200 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm [&_code]:text-ink-900 [&_pre]:mt-4 [&_pre]:overflow-x-auto [&_pre]:rounded-[10px] [&_pre]:bg-ink-900 [&_pre]:p-4 [&_pre]:text-sm [&_pre]:text-paper [&_blockquote]:mt-4 [&_blockquote]:border-l-4 [&_blockquote]:border-ink-300 [&_blockquote]:pl-4 [&_blockquote]:text-ink-500">
      <%= render_markdown(@chapter.body) %>
    </div>

    <nav class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-ink-900/10 pt-8 text-sm font-medium" aria-label="Chapter pagination">
      <% ch_index = @chapters.index(@chapter) %>
      <% prev_ch = ch_index && ch_index.positive? ? @chapters[ch_index - 1] : nil %>
      <% if prev_ch && !chapter_locked?(prev_ch) %>
        <%= link_to "← Previous chapter",
              books_book_chapter_path(@book, prev_ch),
              class: "text-rocket hover:text-rocket-hover" %>
      <% elsif prev_ch %>
        <span class="inline-flex items-center gap-1.5 text-ink-400" aria-disabled="true" title="Subscribe for full access">
          <%= heroicon "lock-closed", variant: :mini, options: { class: "h-4 w-4", "aria-hidden": true } %>
          <span>Previous chapter locked</span>
        </span>
      <% else %>
        <span class="text-ink-400">← Previous chapter</span>
      <% end %>

      <% next_ch = ch_index && ch_index < @chapters.size - 1 ? @chapters[ch_index + 1] : nil %>
      <% if next_ch && !chapter_locked?(next_ch) %>
        <%= link_to "Next chapter →",
              books_book_chapter_path(@book, next_ch),
              class: "text-rocket hover:text-rocket-hover" %>
      <% elsif next_ch %>
        <span class="inline-flex items-center gap-1.5 text-ink-400" aria-disabled="true" title="Subscribe for full access">
          <span>Next chapter locked</span>
          <%= heroicon "lock-closed", variant: :mini, options: { class: "h-4 w-4", "aria-hidden": true } %>
        </span>
      <% else %>
        <span class="text-ink-400">Next chapter →</span>
      <% end %>
    </nav>
  </article>
</div>
