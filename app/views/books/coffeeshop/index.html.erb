<% content_for(:title, "#{@book.title} — Rocketbox") %>

<%= render "shared/page_header" %>

<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12">
  <%= render "toc", chapters: @chapters, active_chapter: nil %>

  <article class="min-w-0 flex-1 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
    <p class="text-sm font-medium text-indigo-600">Mock preview · Coffee shop</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      <%= @book.title %>
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-600">
      A field-style walkthrough for owners who live on the bar during rush. This mock page stands in for the catalog:
      <%= @book.chapters.size %> chapters, each with the same reader layout—navigation on the left, long-form notes on the right.
    </p>

    <div class="mt-8 space-y-4 text-slate-700 leading-relaxed">
      <p>
        Use the table of contents to jump into any chapter. The copy below is placeholder content so designers and engineers
        can wire layout, typography, and paywall seams before the real manuscript ships.
      </p>
      <p>
        In production you might show download links, subscription state, print styles, or “resume where you left off” here on
        the overview.
      </p>
    </div>

    <h2 class="mt-10 text-lg font-semibold text-slate-900">What you’ll find inside</h2>
    <ul class="mt-3 list-inside list-disc space-y-2 text-slate-700">
      <li>Checklists formatted like shift notes, not MBA slides</li>
      <li>Margin and labor prompts you can answer in ten minutes</li>
      <li>Guest-facing scripts for busy bars and tired mornings</li>
    </ul>

    <div class="mt-10 flex flex-wrap gap-3">
      <% first_unlocked = @chapters.find { |c| !chapter_locked?(c) } %>
      <% if first_unlocked %>
        <%= link_to "Start at chapter #{first_unlocked.position}",
              books_coffeeshop_chapter_path(chapter: first_unlocked.position),
              class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      <% end %>
      <% ch10 = @chapters.find { |c| c.position == 10 } %>
      <% if ch10 && !chapter_locked?(ch10) %>
        <%= link_to "Jump to chapter 10",
              books_coffeeshop_chapter_path(chapter: ch10.position),
              class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2" %>
      <% end %>
    </div>
  </article>
</div>
