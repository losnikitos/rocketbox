<% content_for(:title, "Books — Rocketbox") %>

<section class="space-y-8">
  <div>
    <h1 class="font-manrope text-3xl font-extrabold tracking-[-0.02em] text-ink-900 sm:text-4xl">Books</h1>
    <p class="mt-3 max-w-2xl text-[17px] font-medium leading-relaxed text-ink-500">
      Browse the available Rocketbox guides and open any book preview.
    </p>
  </div>

  <% if @books.any? %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% @books.each do |book| %>
        <article class="rb-surface-raised p-5 rb-shadow-card sm:p-6">
          <h2 class="font-manrope text-lg font-bold tracking-tight text-ink-900"><%= book.title %></h2>
          <p class="mt-2 text-sm text-ink-500">
            <%= pluralize(book.chapters.size, "chapter") %> available
          </p>
          <div class="mt-4">
            <%= link_to "Open preview",
                  books_book_path(book),
                  class: "rb-btn-primary px-4 py-2.5 text-sm" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rb-surface-raised p-6 text-ink-500 rb-shadow-card">
      No books are available yet.
    </div>
  <% end %>
</section>
