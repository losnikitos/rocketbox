<%= render layout: "shared/auth_card" do %>
  <% if alert.present? %>
    <p class="<%= tw_alert_error_classes %>"><%= alert %></p>
  <% end %>

  <h1 class="text-center text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Change your password</h1>

  <%= form_with(url: password_path, method: :patch, class: "mt-8 space-y-5") do |form| %>
    <% if @user.errors.any? %>
      <div class="<%= tw_alert_error_classes %> space-y-1" role="alert">
        <p class="font-medium"><%= pluralize(@user.errors.count, "error") %> prevented saving:</p>
        <ul class="list-inside list-disc text-sm">
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :password_challenge, "Current password", class: tw_label_classes %>
      <%= form.password_field :password_challenge, required: true, autofocus: true, autocomplete: "current-password", class: tw_input_classes %>
    </div>

    <div>
      <%= form.label :password, "New password", class: tw_label_classes %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", class: tw_input_classes %>
      <p class="mt-1 text-xs text-slate-500">12 characters minimum.</p>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm new password", class: tw_label_classes %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: tw_input_classes %>
    </div>

    <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:items-center sm:justify-between">
      <%= form.submit "Save changes", class: tw_btn_primary_classes + " sm:w-auto sm:min-w-[10rem]" %>
      <%= link_to "Back", root_path, class: "text-center text-sm font-medium text-slate-600 hover:text-slate-900 sm:text-left" %>
    </div>
  <% end %>
<% end %>
