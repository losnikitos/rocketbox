<% content_for(:title, "Rocketbox — Practical guides for small business owners") %>

<%= render "shared/page_header" %>

<section class="flex flex-col gap-12 pb-8 text-center">
  <div class="flex flex-col items-center gap-5">
    <p class="rounded-full bg-indigo-100 px-4 py-1 text-sm font-medium text-indigo-800">
      Field-tested playbooks · PDF downloads
    </p>
    <h1 class="bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-500 bg-clip-text text-4xl font-bold tracking-tight text-transparent sm:text-5xl">
      Guides built for operators, not theorists
    </h1>
    <p class="max-w-2xl text-lg leading-relaxed text-slate-600">
      Rocketbox sells focused guides for small business owners. Start with a free preview (the first chapter or two, as a PDF). Subscribe to unlock the full book and keep every guide in your corner.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
      <%= link_to "Start with a free preview", new_free_preview_path, class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    </div>
  </div>
</section>
