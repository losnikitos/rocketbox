<% content_for(:title, "Rocketbox — Practical guides for small business owners") %>

<%= render "shared/page_header" %>

<section class="grid gap-12 pb-16 pt-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)] lg:items-center lg:gap-16 lg:pb-20 lg:pt-2">
  <div class="text-left">
    <p class="inline-flex rounded-full border border-ink-900/15 bg-white px-3 py-1.5 text-xs font-medium text-ink-700">
      Field-tested playbooks · PDF downloads
    </p>
    <h1 class="mt-6 font-manrope text-[clamp(2.5rem,6vw,5.5rem)] font-extrabold leading-[1.02] tracking-[-0.035em] text-ink-900 text-balance">
      Run a better<br class="hidden sm:block" />
      small business.<br class="hidden sm:block" />
      One short book at a time.
    </h1>
    <p class="mt-6 max-w-xl text-[17px] font-medium leading-relaxed text-ink-500">
      We sell focused guides for small business owners. Start with a free PDF preview (the first chapter or two). Subscribe for the full book and keep every guide in your corner.
    </p>
    <%= render "shared/subscription_action_buttons", container_class: "mt-8 flex flex-wrap items-center gap-3" %>
  </div>
  <div class="flex justify-center lg:justify-end">
    <%= image_tag "book-refunds.svg", alt: "", class: "w-[min(100%,280px)] rotate-[-2deg] rounded-md rb-shadow-card" %>
  </div>
</section>
