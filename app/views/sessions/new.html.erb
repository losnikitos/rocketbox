<%= render layout: "shared/auth_card" do %>
  <% if notice.present? %>
    <p class="<%= tw_alert_success_classes %>"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="<%= tw_alert_error_classes %>"><%= alert %></p>
  <% end %>

  <h1 class="text-center font-manrope text-xl font-bold tracking-tight text-ink-900 sm:text-2xl">Sign in</h1>
  <p class="mt-1 text-center text-sm text-ink-600">
    <%= link_to "Create an account", sign_up_path, class: "rb-text-link" %>
  </p>

  <%= form_with(url: sign_in_path, class: "mt-8 space-y-5") do |form| %>
    <div>
      <%= form.label :email, class: tw_label_classes %>
      <%= form.email_field :email, value: params[:email_hint], required: true, autofocus: true, autocomplete: "email", class: tw_input_classes %>
    </div>

    <div>
      <%= form.label :password, class: tw_label_classes %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", class: tw_input_classes %>
      <p class="mt-2 text-right text-sm">
        <%= link_to "Forgot your password?", new_identity_password_reset_path, class: "rb-text-link" %>
      </p>
    </div>

    <div class="pt-1">
      <%= form.submit "Sign in", class: tw_btn_primary_classes %>
    </div>
  <% end %>
<% end %>
