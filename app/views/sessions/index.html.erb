<%= render layout: "shared/auth_card", locals: { width: "max-w-2xl" } do %>
  <% if notice.present? %>
    <p class="<%= tw_alert_success_classes %>"><%= notice %></p>
  <% end %>

  <h1 class="text-center font-manrope text-xl font-bold tracking-tight text-ink-900 sm:text-2xl">Devices &amp; sessions</h1>
  <p class="mt-2 text-center text-sm text-ink-600">Signed-in devices for your account.</p>

  <div id="sessions" class="mt-8 space-y-6">
    <% @sessions.each do |session| %>
      <div id="<%= dom_id session %>" class="rounded-[18px] border border-ink-900/10 bg-paper-200 p-4 sm:p-5">
        <dl class="space-y-2 text-sm text-ink-700">
          <div>
            <dt class="font-medium text-ink-900">User agent</dt>
            <dd class="mt-0.5 break-all text-ink-600"><%= session.user_agent %></dd>
          </div>
          <div>
            <dt class="font-medium text-ink-900">IP address</dt>
            <dd class="mt-0.5 text-ink-600"><%= session.ip_address %></dd>
          </div>
          <div>
            <dt class="font-medium text-ink-900">Created</dt>
            <dd class="mt-0.5 text-ink-600"><%= session.created_at %></dd>
          </div>
        </dl>
        <div class="mt-4 border-t border-ink-900/10 pt-4">
          <%= button_to "Log out this session", session, method: :delete, class: "inline-flex cursor-pointer items-center justify-center rounded-[10px] border border-signal-red/40 bg-paper-50 px-4 py-2 text-sm font-semibold text-signal-red transition-colors duration-[160ms] hover:bg-paper-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[rgb(45_107_255/0.5)]" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-8 border-t border-ink-900/10 pt-6 text-center">
    <%= link_to "Back to home", root_path, class: "text-sm rb-text-link" %>
  </div>
<% end %>
