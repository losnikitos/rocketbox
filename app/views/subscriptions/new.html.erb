<% content_for(:title, "Subscribe — Rocketbox") %>

<%= render "shared/page_header" %>

<%= render layout: "shared/auth_card" do %>
  <% if alert.present? %>
    <p class="<%= tw_alert_error_classes %>" role="alert"><%= alert %></p>
  <% end %>

  <h1 class="text-center text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">
    Subscribe to Rocketbox
  </h1>
  <p class="mt-3 text-center text-sm leading-relaxed text-slate-600">
    Leave your email and we’ll send you a secure magic link to continue your Rocketbox subscription.
  </p>

  <%= form_with model: @request, url: subscription_path, class: "mt-8 space-y-5", method: :post do |form| %>
    <% if @request.errors.any? %>
      <div class="<%= tw_alert_error_classes %> space-y-1" role="alert">
        <p class="font-medium"><%= pluralize(@request.errors.count, "issue") %> to fix:</p>
        <ul class="list-inside list-disc text-sm">
          <% @request.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email, class: tw_label_classes %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email", class: tw_input_classes %>
    </div>

    <div class="pt-1">
      <%= form.submit "Subscribe", class: tw_btn_primary_classes %>
    </div>

    <p class="text-center text-xs text-slate-500">
      Already have an account?
      <%= link_to "Sign in", sign_in_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
    </p>
  <% end %>
<% end %>
