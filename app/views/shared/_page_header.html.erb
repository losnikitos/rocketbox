<header class="mb-10 border-b border-ink-900/10 pb-6">
  <nav class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between" aria-label="Primary">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm font-medium">
      <%= render "shared/logo" %>
      <%= link_to "Home", root_path, class: class_names("font-medium transition-colors", (current_page?(root_path) ? "text-ink-900" : "text-ink-500 hover:text-ink-900")), aria: (current_page?(root_path) ? { current: "page" } : {}) %>
      <%= link_to "Books", books_path, class: class_names("font-medium transition-colors", (request.path.start_with?("/books") ? "text-ink-900" : "text-ink-500 hover:text-ink-900")) %>
    </div>
    <div class="flex flex-wrap items-center gap-3 sm:justify-end">
      <%= link_to "Pricing", "#{root_path}#pricing", class: "text-sm font-medium text-ink-500 transition-colors hover:text-ink-900" %>
      <% if Current.user %>
        <%= link_to "My account", account_path, class: "rb-btn-ghost px-3 py-2 text-sm" %>
      <% else %>
        <%= link_to "Sign in", sign_in_path, class: "rb-btn-ghost px-3 py-2 text-sm" %>
      <% end %>
    </div>
  </nav>
</header>
