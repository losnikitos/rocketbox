<%= render layout: "shared/auth_card" do %>
  <% if alert.present? %>
    <p class="<%= tw_alert_error_classes %>"><%= alert %></p>
  <% end %>

  <h1 class="text-center text-xl font-semibold tracking-tight text-slate-900 sm:text-2xl">Forgot your password?</h1>
  <p class="mt-2 text-center text-sm text-slate-600">
    Enter your email and we&apos;ll send you a reset link.
  </p>

  <%= form_with(url: identity_password_reset_path, class: "mt-8 space-y-5") do |form| %>
    <div>
      <%= form.label :email, class: tw_label_classes %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email", class: tw_input_classes %>
    </div>

    <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:items-center sm:justify-between">
      <%= form.submit "Send reset email", class: tw_btn_primary_classes + " sm:w-auto sm:min-w-[10rem]" %>
      <%= link_to "Back to sign in", sign_in_path, class: "text-center text-sm font-medium text-indigo-600 hover:text-indigo-500 sm:text-left" %>
    </div>
  <% end %>
<% end %>
