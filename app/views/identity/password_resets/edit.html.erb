<%= render layout: "shared/auth_card" do %>
  <h1 class="text-center font-manrope text-xl font-bold tracking-tight text-ink-900 sm:text-2xl">Reset your password</h1>
  <p class="mt-2 text-center text-sm text-ink-600">Choose a new password for your account.</p>

  <%= form_with(url: identity_password_reset_path, method: :patch, class: "mt-8 space-y-5") do |form| %>
    <% if @user.errors.any? %>
      <div class="<%= tw_alert_error_classes %> space-y-1" role="alert">
        <p class="font-medium"><%= pluralize(@user.errors.count, "error") %> prevented saving:</p>
        <ul class="list-inside list-disc text-sm">
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form.hidden_field :sid, value: params[:sid] %>

    <div>
      <%= form.label :password, "New password", class: tw_label_classes %>
      <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password", class: tw_input_classes %>
      <p class="mt-1 text-xs text-ink-500">12 characters minimum.</p>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm new password", class: tw_label_classes %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: tw_input_classes %>
    </div>

    <div class="pt-1">
      <%= form.submit "Save new password", class: tw_btn_primary_classes %>
    </div>
  <% end %>
<% end %>
